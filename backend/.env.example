# ===========================================
# CONFIGURACIÓN DEL SERVIDOR
# ===========================================
PORT=3000
LOG_LEVEL=info

# ===========================================
# BASE DE DATOS (PostgreSQL)
# ===========================================
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/seguridad"

# ===========================================
# AUTENTICACIÓN (JWT)
# ===========================================
JWT_SECRET="genera_un_secreto_seguro_aqui"

# ===========================================
# CONFIGURACIÓN DE RED
# ===========================================
# IP del broker MQTT (puede ser localhost o IP de red)
MQTT_BROKER_HOST="localhost"
MQTT_BROKER_PORT=1883

# URL base de la API para clientes (frontend, ESP32)
API_BASE_URL="http://localhost:3000"

# URL de conexión MQTT (opcional - sobrescribe MQTT_BROKER_HOST y MQTT_BROKER_PORT)
# MQTT_URL="mqtt://localhost:1883"

# ===========================================
# TWILIO (SMS - Opcional)
# ===========================================
TWILIO_ACCOUNT_SID="tu_account_sid_aqui"
TWILIO_AUTH_TOKEN="tu_auth_token_aqui"
TWILIO_PHONE_NUMBER="+1234567890"

# ===========================================
# FIREBASE (Notificaciones Push - Opcional)
# ===========================================
FIREBASE_PROJECT_ID="tu_project_id_aqui"
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase/service-account.json"
